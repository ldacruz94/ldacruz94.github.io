---
import { getCollection } from 'astro:content';
import { professionalProjects } from '../data/projects/professional';
import { freelanceProjects } from '../data/projects/freelance';
import { personalProjects } from '../data/projects/personal';
import { academicProjects } from '../data/projects/academic';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const allProjects = [
	...professionalProjects,
	...freelanceProjects,
	...personalProjects,
	...academicProjects,
];

const items = [
	{ label: 'Home',     url: '/',         group: 'Navigation', description: 'About me'           },
	{ label: 'Blog',     url: '/blog',     group: 'Navigation', description: 'Writing & thoughts' },
	{ label: 'Projects', url: '/projects', group: 'Navigation', description: "What I've built"    },
	{ label: 'Library',  url: '/library',  group: 'Navigation', description: "Books I've read"    },
	...posts.map(p => ({
		label:       p.data.title,
		url:         `/blog/${p.id}/`,
		group:       'Posts',
		description: p.data.description,
	})),
	...allProjects.map(p => ({
		label:       p.title,
		url:         p.link,
		group:       'Projects',
		description: p.type,
		keywords:    p.technologies?.join(' ') ?? '',
		isExternal:  true,
	})),
];
---

<div id="cp-overlay" aria-hidden="true">
	<div id="cp-modal" role="dialog" aria-modal="true" aria-label="Command palette">
		<div id="cp-search-row">
			<svg id="cp-search-icon" xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
				<circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
			</svg>
			<svg id="cp-ai-icon" xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
				<path d="M12 2l1.09 3.26L16.5 6.5l-3.41 1.24L12 11l-1.09-3.26L7.5 6.5l3.41-1.24L12 2z"/>
				<path d="M5 14l.65 1.96L7.6 17l-1.95.65L5 19.6l-.65-1.95L2.4 17l1.95-.65L5 14z"/>
				<path d="M19 14l.65 1.96L21.6 17l-1.95.65L19 19.6l-.65-1.95L16.4 17l1.95-.65L19 14z"/>
			</svg>
			<input id="cp-input" type="text" placeholder="Search pages, posts, projects…" autocomplete="off" spellcheck="false" aria-label="Search" />
			<button id="cp-close-btn" aria-label="Close palette">Esc</button>
		</div>
		<div id="cp-results" role="listbox" aria-label="Results"></div>
		<div id="cp-footer">
			<span><kbd>↑</kbd><kbd>↓</kbd> navigate</span>
			<span><kbd>↵</kbd> open</span>
			<span><kbd>Esc</kbd> close</span>
			<span id="cp-ai-badge">✦ AI mode</span>
		</div>
	</div>
</div>

<style>
	#cp-overlay {
		position: fixed;
		inset: 0;
		background: rgba(0, 0, 0, 0.45);
		backdrop-filter: blur(4px);
		-webkit-backdrop-filter: blur(4px);
		z-index: 9000;
		display: flex;
		align-items: flex-start;
		justify-content: center;
		padding-top: 14vh;
		opacity: 0;
		pointer-events: none;
		transition: opacity 0.15s ease;
	}
	#cp-overlay.open {
		opacity: 1;
		pointer-events: auto;
	}
	#cp-modal {
		width: 100%;
		max-width: 560px;
		margin: 0 1em;
		background: var(--bg);
		border: 1px solid rgba(129, 140, 248, 0.2);
		border-radius: 12px;
		box-shadow: 0 24px 48px rgba(0, 0, 0, 0.55), 0 0 0 1px rgba(129, 140, 248, 0.05);
		overflow: hidden;
		transform: scale(0.97) translateY(-6px);
		transition: transform 0.15s ease;
	}
	#cp-overlay.open #cp-modal {
		transform: scale(1) translateY(0);
	}
	#cp-search-row {
		display: flex;
		align-items: center;
		gap: 0.6em;
		padding: 0.85em 1em;
		border-bottom: 1px solid rgba(129, 140, 248, 0.1);
	}
	#cp-search-icon {
		color: rgb(var(--gray));
		flex-shrink: 0;
	}
	#cp-input {
		flex: 1;
		background: transparent;
		border: none;
		outline: none;
		font-family: inherit;
		font-size: 0.95em;
		color: rgb(var(--black));
		caret-color: var(--accent);
		min-width: 0;
	}
	#cp-input::placeholder {
		color: rgb(var(--gray));
	}
	#cp-close-btn {
		background: rgba(129, 140, 248, 0.07);
		border: 1px solid rgba(129, 140, 248, 0.15);
		border-radius: 4px;
		padding: 0.15em 0.5em;
		font-size: 0.72em;
		color: rgb(var(--gray));
		cursor: pointer;
		font-family: inherit;
		flex-shrink: 0;
		line-height: 1.6;
		transition: border-color 0.15s ease, color 0.15s ease;
	}
	#cp-close-btn:hover {
		border-color: var(--accent);
		color: var(--accent);
	}
	#cp-results {
		max-height: 360px;
		overflow-y: auto;
		padding: 0.4em 0;
	}
	:global(.cp-group-header) {
		padding: 0.5em 1em 0.2em;
		font-size: 0.68em;
		font-weight: 700;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: rgb(var(--gray));
	}
	:global(.cp-item) {
		display: flex;
		align-items: center;
		gap: 0.75em;
		padding: 0.6em 1em;
		text-decoration: none;
		color: rgb(var(--gray-dark));
		cursor: pointer;
		border-left: 2px solid transparent;
		transition: background 0.1s ease, border-color 0.1s ease;
	}
	:global(.cp-item:hover),
	:global(.cp-item.selected) {
		background: rgba(129, 140, 248, 0.07);
		color: rgb(var(--black));
		border-left-color: var(--accent);
	}
	:global(.cp-item-body) {
		flex: 1;
		min-width: 0;
		display: flex;
		flex-direction: column;
		gap: 0.1em;
	}
	:global(.cp-item-label) {
		font-size: 0.88em;
		font-weight: 500;
		color: rgb(var(--black));
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
	}
	:global(.cp-item-desc) {
		font-size: 0.76em;
		color: rgb(var(--gray));
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
	}
	:global(.cp-item mark) {
		background: rgba(129, 140, 248, 0.22);
		color: var(--accent);
		border-radius: 2px;
		padding: 0 1px;
	}
	:global(.cp-item-ext) {
		font-size: 0.72em;
		color: rgb(var(--gray));
		flex-shrink: 0;
		opacity: 0.5;
	}
	:global(.cp-empty),
	:global(.cp-hint) {
		padding: 1.5em 1em;
		text-align: center;
		color: rgb(var(--gray));
		font-size: 0.85em;
		margin: 0;
	}
	#cp-footer {
		display: flex;
		gap: 1.25em;
		padding: 0.55em 1em;
		border-top: 1px solid rgba(129, 140, 248, 0.08);
		font-size: 0.7em;
		color: rgb(var(--gray));
	}
	#cp-footer kbd {
		display: inline-block;
		padding: 0.1em 0.35em;
		background: rgba(129, 140, 248, 0.07);
		border: 1px solid rgba(129, 140, 248, 0.15);
		border-radius: 3px;
		font-family: inherit;
		font-size: 0.95em;
		line-height: 1.5;
	}
	html[data-theme="light"] #cp-modal {
		box-shadow: 0 24px 48px rgba(0, 0, 0, 0.12), 0 0 0 1px rgba(129, 140, 248, 0.08);
	}
	#cp-ai-icon {
		color: var(--accent);
		flex-shrink: 0;
		display: none;
	}
	#cp-modal.ai-mode #cp-search-icon { display: none; }
	#cp-modal.ai-mode #cp-ai-icon     { display: block; }
	#cp-modal.ai-mode {
		border-color: rgba(129, 140, 248, 0.45);
		box-shadow: 0 24px 48px rgba(0,0,0,0.55), 0 0 0 1px rgba(129,140,248,0.12), 0 0 24px rgba(129,140,248,0.08);
	}
	#cp-ai-badge {
		margin-left: auto;
		background: rgba(129, 140, 248, 0.1);
		border: 1px solid rgba(129, 140, 248, 0.2);
		border-radius: 4px;
		padding: 0.1em 0.5em;
		color: var(--accent);
		display: none;
		letter-spacing: 0.02em;
	}
	#cp-modal.ai-mode #cp-ai-badge { display: inline; }
</style>

<script define:vars={{ items }}>
	function initCommandPalette() {
		if (window._cpController) window._cpController.abort();
		window._cpController = new AbortController();
		const { signal } = window._cpController;

		const overlay  = document.getElementById('cp-overlay');
		const input    = document.getElementById('cp-input');
		const results  = document.getElementById('cp-results');
		const closeBtn = document.getElementById('cp-close-btn');
		if (!overlay || !input || !results) return;

		let selectedIdx = -1;
		let flatItems   = [];

		function openPalette() {
			overlay.classList.add('open');
			overlay.removeAttribute('aria-hidden');
			input.value = '';
			renderResults('');
			requestAnimationFrame(() => input.focus());
		}

		function closePalette() {
			overlay.classList.remove('open');
			overlay.setAttribute('aria-hidden', 'true');
			selectedIdx = -1;
			flatItems   = [];
			document.getElementById('cp-modal')?.classList.remove('ai-mode');
		}

		window.openCommandPalette = openPalette;

		function escape(str) {
			return str
				.replace(/&/g, '&amp;')
				.replace(/</g, '&lt;')
				.replace(/>/g, '&gt;')
				.replace(/"/g, '&quot;');
		}

		function highlight(text, query) {
			if (!query) return escape(text);
			const safe = query.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
			return escape(text).replace(new RegExp(safe, 'gi'), m => `<mark>${m}</mark>`);
		}

		function renderResults(query) {
			const q = query.toLowerCase().trim();
			results.innerHTML = '';
			flatItems   = [];
			selectedIdx = -1;

			const visible = q
				? items.filter(i =>
						i.label.toLowerCase().includes(q) ||
						(i.description && i.description.toLowerCase().includes(q)) ||
						(i.keywords && i.keywords.toLowerCase().includes(q))
					)
				: items.filter(i => i.group === 'Navigation');

			if (!q) {
				appendGroup('Navigation', visible, q);
				const hint = document.createElement('p');
				hint.className = 'cp-hint';
				hint.textContent = 'Type to search posts and projects…';
				results.appendChild(hint);
				return;
			}

			if (visible.length === 0) {
				const empty = document.createElement('p');
				empty.className = 'cp-empty';
				empty.textContent = `No results for "${query}"`;
				results.appendChild(empty);
				return;
			}

			const groups = new Map();
			for (const item of visible) {
				if (!groups.has(item.group)) groups.set(item.group, []);
				groups.get(item.group).push(item);
			}
			for (const [group, groupItems] of groups) {
				appendGroup(group, groupItems, q);
			}

			if (flatItems.length > 0) setSelected(0);
		}

		function appendGroup(label, groupItems, query) {
			const header = document.createElement('div');
			header.className = 'cp-group-header';
			header.textContent = label;
			results.appendChild(header);
			groupItems.forEach(item => appendItem(item, query));
		}

		function appendItem(item, query) {
			const idx = flatItems.length;
			const a = document.createElement('a');
			a.href = item.url;
			a.className = 'cp-item';
			a.setAttribute('role', 'option');
			if (item.isExternal) {
				a.target = '_blank';
				a.rel = 'noopener noreferrer';
			}

			const body = document.createElement('div');
			body.className = 'cp-item-body';

			const labelEl = document.createElement('span');
			labelEl.className = 'cp-item-label';
			labelEl.innerHTML = highlight(item.label, query);
			body.appendChild(labelEl);

			if (item.description) {
				const descEl = document.createElement('span');
				descEl.className = 'cp-item-desc';
				descEl.textContent = item.description;
				body.appendChild(descEl);
			}

			a.appendChild(body);

			if (item.isExternal) {
				const ext = document.createElement('span');
				ext.className = 'cp-item-ext';
				ext.textContent = '↗';
				ext.setAttribute('aria-hidden', 'true');
				a.appendChild(ext);
			}

			a.addEventListener('mouseenter', () => setSelected(idx));
			a.addEventListener('click', closePalette);
			results.appendChild(a);
			flatItems.push(a);
		}

		function setSelected(idx) {
			if (selectedIdx >= 0 && flatItems[selectedIdx]) {
				flatItems[selectedIdx].classList.remove('selected');
			}
			selectedIdx = idx;
			if (idx >= 0 && flatItems[idx]) {
				flatItems[idx].classList.add('selected');
				flatItems[idx].scrollIntoView({ block: 'nearest' });
			}
		}

		document.addEventListener('keydown', (e) => {
			if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
				e.preventDefault();
				overlay.classList.contains('open') ? closePalette() : openPalette();
				return;
			}
			if (!overlay.classList.contains('open')) return;

			if      (e.key === 'Escape')    { e.preventDefault(); closePalette(); }
			else if (e.key === 'ArrowDown') { e.preventDefault(); setSelected(Math.min(selectedIdx + 1, flatItems.length - 1)); }
			else if (e.key === 'ArrowUp')   { e.preventDefault(); setSelected(Math.max(selectedIdx - 1, 0)); }
			else if (e.key === 'Enter' && selectedIdx >= 0 && flatItems[selectedIdx]) {
				e.preventDefault();
				flatItems[selectedIdx].click();
			}
		}, { signal });

		const STOP_WORDS = new Set(['a','an','the','is','in','on','at','to','for','of','and','or','with','has','have','what','where','when','who','how','show','me','find','get','i','that','this','do','did','does','about','any','all','built','using','use']);

		function tokenize(text) {
			return text.toLowerCase().split(/\W+/).filter(t => t.length > 1 && !STOP_WORDS.has(t));
		}

		function scoreItem(item, tokens) {
			let score = 0;
			const label = item.label.toLowerCase();
			const desc  = (item.description || '').toLowerCase();
			const kw    = (item.keywords    || '').toLowerCase();
			for (const token of tokens) {
				if (label.includes(token)) score += 3;
				if (desc.includes(token))  score += 2;
				if (kw.includes(token))    score += 2;
			}
			return score;
		}

		function renderAIResults(rawQuery) {
			const modal = document.getElementById('cp-modal');
			modal?.classList.add('ai-mode');
			input.placeholder = 'Ask about my work, projects, writing…';
			results.innerHTML = '';
			flatItems   = [];
			selectedIdx = -1;

			if (!rawQuery.trim()) {
				const hint = document.createElement('p');
				hint.className = 'cp-hint';
				hint.textContent = 'Ask anything about my work, projects, or writing…';
				results.appendChild(hint);
				return;
			}

			const tokens = tokenize(rawQuery);
			if (tokens.length === 0) return;

			const scored = items
				.map(item => ({ item, score: scoreItem(item, tokens) }))
				.filter(({ score }) => score > 0)
				.sort((a, b) => b.score - a.score)
				.map(({ item }) => item);

			if (scored.length === 0) {
				const empty = document.createElement('p');
				empty.className = 'cp-empty';
				empty.textContent = `Nothing found for "${rawQuery}"`;
				results.appendChild(empty);
				return;
			}

			appendGroup('Results', scored, rawQuery);
			if (flatItems.length > 0) setSelected(0);
		}

		input.addEventListener('input', () => {
			const val = input.value;
			const modal = document.getElementById('cp-modal');
			if (val.startsWith('>')) {
				renderAIResults(val.slice(1).trimStart());
			} else {
				modal?.classList.remove('ai-mode');
				input.placeholder = 'Search pages, posts, projects…';
				renderResults(val);
			}
		}, { signal });
		closeBtn?.addEventListener('click', closePalette, { signal });
		overlay.addEventListener('click', (e) => { if (e.target === overlay) closePalette(); }, { signal });
	}

	document.addEventListener('astro:page-load', initCommandPalette);
	initCommandPalette();
</script>
