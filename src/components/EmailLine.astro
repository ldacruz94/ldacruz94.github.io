---
import SidebarLine from './SidebarLine.astro';
interface Props {
	email: string;
}
const { email } = Astro.props;
---

<SidebarLine side="right">
	<a href={`mailto:${email}`} class="email" id="email-link" data-email={email}>{email}</a>
</SidebarLine>

<style>
.email {
	writing-mode: vertical-rl;
	text-decoration: none;
	color: rgb(var(--gray-dark));
	font-size: 0.9rem;
	transition: color 0.2s ease;
	cursor: pointer;
}

.email:hover {
	color: var(--accent);
	font-size: 0.95rem;
}
</style>

<script>
function initEmailCopy() {
	const link = document.getElementById('email-link') as HTMLAnchorElement | null;
	if (!link || (link as any)._copyInit) return;
	(link as any)._copyInit = true;

	link.addEventListener('click', async (e) => {
		e.preventDefault();
		const addr = (link as HTMLAnchorElement).dataset.email ?? link.textContent?.trim() ?? '';
		try {
			await navigator.clipboard.writeText(addr);
			const original = link.textContent;
			link.textContent = 'Copied!';
			link.style.color = 'var(--accent)';
			setTimeout(() => {
				link.textContent = original;
				link.style.color = '';
			}, 1500);
		} catch {
			window.location.href = link.href;
		}
	});
}

document.addEventListener('astro:page-load', initEmailCopy);
</script>
