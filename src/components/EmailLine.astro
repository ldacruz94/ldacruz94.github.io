---
  interface Props {
	email: string;
  }
  const { email } = Astro.props;
---

<div class="right-line">
	<a href={`mailto:${email}`} class="email" id="email-link" data-email={email}>{email}</a>
	<div class="line-wrap">
		<div class="line"></div>
		<canvas class="helix-canvas" width="20" height="100"></canvas>
	</div>
</div>

<style>
.right-line {
	position: fixed;
	right: 2rem;
	bottom: 0;
	display: flex;
	flex-direction: column;
	align-items: center;
	opacity: 0;
	animation: fadeIn 1s ease-in-out forwards;
	animation-delay: 2.5s;
}

:global(html.header-animated) .right-line {
	opacity: 1;
	animation: none;
}

.line-wrap {
	position: relative;
	margin-top: 1rem;
	width: 20px;
	height: 100px;
	display: flex;
	justify-content: center;
}

.line {
	width: 2px;
	height: 100px;
	background-color: rgb(var(--gray));
	position: relative;
	overflow: hidden;
}

.helix-canvas {
	position: absolute;
	top: 0;
	left: 0;
	pointer-events: none;
}

.line::after {
	content: '';
	position: absolute;
	bottom: 0;
	left: 0;
	width: 100%;
	height: 0;
	background: linear-gradient(to top, var(--accent), rgba(129, 140, 248, 0.2));
	animation: lineColorFill 1.5s ease-out forwards;
	animation-delay: 3.5s;
}

@keyframes lineColorFill {
	from { height: 0; }
	to { height: 100%; }
}

.email {
	writing-mode: vertical-rl;
	text-decoration: none;
	color: rgb(var(--gray-dark));
	font-size: 0.9rem;
	transition: color 0.2s ease;
	cursor: pointer;
}

.email:hover {
	color: var(--accent);
	font-size: 0.95rem;
}

</style>

<script>
function initEmailCopy() {
	const link = document.getElementById('email-link') as HTMLAnchorElement | null;
	if (!link || (link as any)._copyInit) return;
	(link as any)._copyInit = true;

	link.addEventListener('click', async (e) => {
		e.preventDefault();
		const addr = (link as HTMLAnchorElement).dataset.email ?? link.textContent?.trim() ?? '';
		try {
			await navigator.clipboard.writeText(addr);
			const original = link.textContent;
			link.textContent = 'Copied!';
			link.style.color = 'var(--accent)';
			setTimeout(() => {
				link.textContent = original;
				link.style.color = '';
			}, 1500);
		} catch {
			window.location.href = link.href;
		}
	});
}

initEmailCopy();
document.addEventListener('astro:page-load', initEmailCopy);
</script>