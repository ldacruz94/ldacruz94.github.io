---
interface Props {
	projects: Array<{
		type: string;
		technologies: string[];
		[key: string]: any;
	}>;
}

const { projects } = Astro.props;
const projectTypes = Array.from(new Set(projects.filter((p) => p.type).map((p) => p.type)));
const projectTechs = Array.from(new Set(projects.flatMap((p) => p.technologies || []))).sort();
---

<div class="filter-bar">
	<div class="filter-section">
		<span class="filter-label">Type</span>
		<div class="pill-group" id="type-pills">
			<button class="pill active" data-value="">All</button>
			{projectTypes.map((type: string) => (
				<button class="pill" data-value={type}>{type}</button>
			))}
		</div>
	</div>

	<div class="filter-section">
		<span class="filter-label">Technology</span>
		<div class="pill-group" id="tech-pills">
			<button class="pill active" data-value="">All</button>
			{projectTechs.map((tech: string) => (
				<button class="pill" data-value={tech}>{tech}</button>
			))}
		</div>
	</div>

	<p class="project-count">
		<span id="visible-count">{projects.length}</span> project{projects.length !== 1 ? "s" : ""}
	</p>
</div>

<style>
	.filter-bar {
		margin-bottom: 2em;
		display: flex;
		flex-direction: column;
		gap: 1em;
	}

	.filter-section {
		display: flex;
		align-items: flex-start;
		gap: 0.75em;
		flex-wrap: wrap;
	}

	.filter-label {
		font-size: 0.8em;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: rgb(var(--gray));
		padding-top: 0.45em;
		white-space: nowrap;
		min-width: 6em;
	}

	.pill-group {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4em;
	}

	.pill {
		padding: 0.3em 0.85em;
		border-radius: 999px;
		border: 1.5px solid rgba(255, 255, 255, 0.12);
		background: transparent;
		color: rgb(var(--gray-dark));
		font-size: 0.82em;
		font-weight: 500;
		cursor: pointer;
		transition: all 0.15s ease;
		font-family: inherit;
		line-height: 1.5;
	}

	.pill:hover {
		border-color: rgb(var(--accent));
		color: rgb(var(--accent));
	}

	.pill.active {
		background: rgb(var(--accent));
		border-color: rgb(var(--accent));
		color: #fff;
	}

	.project-count {
		margin: 0;
		font-size: 0.85em;
		color: rgb(var(--gray));
	}
</style>

<script>
	let filterController: AbortController | null = null;

	function initFilters() {
		if (filterController) filterController.abort();
		filterController = new AbortController();
		const { signal } = filterController;

		const typePills = document.querySelectorAll<HTMLButtonElement>("#type-pills .pill");
		const techPills = document.querySelectorAll<HTMLButtonElement>("#tech-pills .pill");
		const items = document.querySelectorAll<HTMLElement>(".project-item");
		const countEl = document.getElementById("visible-count");

		if (!typePills.length) return;

		let activeType = "";
		let activeTech = "";

		function applyFilters() {
			let visible = 0;
			items.forEach((item) => {
				const type = item.dataset.type ?? "";
				const techs = item.dataset.technologies?.split(",") ?? [];
				const show =
					(!activeType || type === activeType) &&
					(!activeTech || techs.includes(activeTech));

				item.style.display = show ? "" : "none";
				if (show) visible++;
			});
			if (countEl) countEl.textContent = String(visible);
		}

		typePills.forEach((pill) => {
			pill.addEventListener("click", () => {
				typePills.forEach((p) => p.classList.remove("active"));
				pill.classList.add("active");
				activeType = pill.dataset.value ?? "";
				applyFilters();
			}, { signal });
		});

		techPills.forEach((pill) => {
			pill.addEventListener("click", () => {
				techPills.forEach((p) => p.classList.remove("active"));
				pill.classList.add("active");
				activeTech = pill.dataset.value ?? "";
				applyFilters();
			}, { signal });
		});
	}

	initFilters();
	document.addEventListener('astro:page-load', initFilters);
</script>
