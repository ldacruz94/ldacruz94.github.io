<div id="robot-buddy" role="button" tabindex="0" aria-label="Robot buddy" transition:persist="robot-buddy">
	<div id="robot-bubble" class="robot-bubble"></div>
	<svg viewBox="0 0 40 56" width="48" height="67" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
		<!-- Antenna -->
		<line x1="20" y1="8" x2="20" y2="2" stroke="var(--accent)" stroke-width="2" stroke-linecap="round"/>
		<circle cx="20" cy="1.5" r="2.5" fill="var(--accent)"/>
		<!-- Head -->
		<rect x="4" y="8" width="32" height="20" rx="4"
			fill="rgba(129,140,248,0.12)" stroke="var(--accent)" stroke-width="1.5"/>
		<!-- Eyes -->
		<circle class="robot-eye" cx="14" cy="17" r="3" fill="var(--accent)"/>
		<circle class="robot-eye" cx="26" cy="17" r="3" fill="var(--accent)" style="animation-delay:0.1s"/>
		<!-- Mouth -->
		<path d="M14 23 Q20 27 26 23" stroke="var(--accent)" stroke-width="1.5" fill="none" stroke-linecap="round"/>
		<!-- Body -->
		<rect x="8" y="30" width="24" height="16" rx="3"
			fill="rgba(129,140,248,0.12)" stroke="var(--accent)" stroke-width="1.5"/>
		<!-- Chest light -->
		<circle cx="20" cy="38" r="2.5" fill="var(--accent)" opacity="0.7" class="robot-chest"/>
		<!-- Left arm -->
		<rect x="1" y="31" width="6" height="10" rx="3"
			fill="rgba(129,140,248,0.12)" stroke="var(--accent)" stroke-width="1.5"/>
		<!-- Right arm (waving) -->
		<g class="robot-arm-right">
			<rect x="33" y="31" width="6" height="10" rx="3"
				fill="rgba(129,140,248,0.12)" stroke="var(--accent)" stroke-width="1.5"/>
		</g>
		<!-- Legs -->
		<rect x="11" y="47" width="7" height="9" rx="3"
			fill="rgba(129,140,248,0.12)" stroke="var(--accent)" stroke-width="1.5"/>
		<rect x="22" y="47" width="7" height="9" rx="3"
			fill="rgba(129,140,248,0.12)" stroke="var(--accent)" stroke-width="1.5"/>
	</svg>
</div>

<style>
	#robot-buddy {
		position: fixed;
		right: 28px;
		top: 35%;
		transform: translateY(-50%);
		z-index: 8000;
		cursor: pointer;
		user-select: none;
		animation: robot-bob 3s ease-in-out infinite;
		transition: filter 0.2s ease;
		display: none;
	}
	@media (min-width: 768px) {
		#robot-buddy { display: block; }
	}
	#robot-buddy:hover {
		filter: brightness(1.25);
	}
	#robot-buddy.waving {
		animation: robot-jump 0.55s ease-out forwards;
	}
	@keyframes robot-bob {
		0%, 100% { transform: translateY(-50%); }
		50%       { transform: translateY(calc(-50% - 5px)); }
	}
	@keyframes robot-jump {
		0%   { transform: translateY(-50%); }
		35%  { transform: translateY(calc(-50% - 10px)); }
		65%  { transform: translateY(calc(-50% - 6px)); }
		100% { transform: translateY(-50%); }
	}

	.robot-bubble {
		position: absolute;
		top: 50%;
		right: calc(100% + 10px);
		transform: translateY(-50%) scale(0.9) translateX(4px);
		background: var(--bg);
		border: 1px solid rgba(129, 140, 248, 0.35);
		border-radius: 8px;
		padding: 0.45em 0.85em;
		font-size: 0.75em;
		font-family: inherit;
		color: rgb(var(--black));
		white-space: nowrap;
		opacity: 0;
		pointer-events: none;
		transition: opacity 0.18s ease, transform 0.18s ease;
		box-shadow: 0 4px 14px rgba(0, 0, 0, 0.25);
	}
	.robot-bubble.visible {
		opacity: 1;
		transform: translateY(-50%) scale(1) translateX(0);
	}

	.robot-eye {
		transform-box: fill-box;
		transform-origin: 50% 50%;
		animation: eye-blink 5s ease-in-out infinite;
	}
	.robot-chest {
		animation: chest-pulse 2.5s ease-in-out infinite;
	}
	.robot-arm-right {
		transform-box: fill-box;
		transform-origin: 50% 0%;
	}
	#robot-buddy.waving .robot-arm-right {
		animation: robot-wave 0.85s ease-in-out;
	}

	@keyframes eye-blink {
		0%, 92%, 100% { transform: scaleY(1); }
		95%, 97%      { transform: scaleY(0.1); }
	}
	@keyframes chest-pulse {
		0%, 100% { opacity: 0.7; }
		50%      { opacity: 0.25; }
	}
	@keyframes robot-wave {
		0%   { transform: rotate(0deg); }
		20%  { transform: rotate(-42deg); }
		40%  { transform: rotate(-18deg); }
		60%  { transform: rotate(-48deg); }
		80%  { transform: rotate(-20deg); }
		100% { transform: rotate(0deg); }
	}
</style>

<script>
	function initRobot() {
		const robot  = document.getElementById('robot-buddy');
		const bubble = document.getElementById('robot-bubble');
		if (!robot || !bubble || (robot as any)._robotInit) return;
		(robot as any)._robotInit = true;

		const messages = [
			'Beep boop! 👋',
			'Hello, human!',
			'Built by Lucas ⚡',
			'I run on neural nets ☕',
			'01001000 01101001',
			'// TODO: world domination',
			'Nice to meet you!',
			'Have you seen my projects?',
		];

		let msgIndex   = 0;
		let bubbleTimer: ReturnType<typeof setTimeout> | null = null;

		function showBubble() {
			bubble!.textContent = messages[msgIndex % messages.length];
			msgIndex++;
			bubble!.classList.add('visible');
			if (bubbleTimer) clearTimeout(bubbleTimer);
			bubbleTimer = setTimeout(() => bubble!.classList.remove('visible'), 2800);
		}

		robot.addEventListener('click', () => {
			robot.classList.remove('waving');
			void (robot as HTMLElement).offsetWidth;
			robot.classList.add('waving');
			setTimeout(() => robot.classList.remove('waving'), 900);
			showBubble();
		});

		robot.addEventListener('keydown', (e) => {
			if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); robot.click(); }
		});
	}

	document.addEventListener('astro:page-load', initRobot);
	initRobot();
</script>
