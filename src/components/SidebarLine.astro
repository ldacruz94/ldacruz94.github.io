---
interface Props {
	side: 'left' | 'right';
}
const { side } = Astro.props;
---

<div class={`sidebar-line sidebar-line--${side}`}>
	<slot />
	<div class="line-wrap">
		<div class="line"></div>
		<canvas class="helix-canvas" width="20" height="100"></canvas>
	</div>
</div>

<style>
.sidebar-line {
	position: fixed;
	bottom: 0;
	display: flex;
	flex-direction: column;
	align-items: center;
	opacity: 0;
	animation: fadeIn 1s ease-in-out forwards;
	animation-delay: 2.5s;
}

.sidebar-line--left  { left: 2rem; }
.sidebar-line--right { right: 2rem; }

:global(html.header-animated) .sidebar-line {
	opacity: 1;
	animation: none;
}

.line-wrap {
	position: relative;
	margin-top: 1rem;
	width: 20px;
	height: 100px;
	display: flex;
	justify-content: center;
}

.line {
	width: 2px;
	height: 100px;
	background-color: rgb(var(--gray));
	position: relative;
	overflow: hidden;
}

.helix-canvas {
	position: absolute;
	top: 0;
	left: 0;
	pointer-events: none;
}

.line::after {
	content: '';
	position: absolute;
	bottom: 0;
	left: 0;
	width: 100%;
	height: 0;
	background: linear-gradient(to top, var(--accent), rgba(129, 140, 248, 0.2));
	animation: lineColorFill 1.5s ease-out forwards;
	animation-delay: 3.5s;
}

@keyframes lineColorFill {
	from { height: 0; }
	to   { height: 100%; }
}

:global(html[data-theme="light"]) .line {
	background-color: rgba(0, 0, 0, 0.15);
}
</style>
