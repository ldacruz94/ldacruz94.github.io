---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE, SITE_DESCRIPTION, EMAIL } from '../../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';
import EmailLine from '../../components/EmailLine.astro';
import SocialMediaLine from '../../components/SocialMediaLine.astro';
import Footer from '../../components/Footer.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const postsWithMeta = posts.map((post) => {
	const wordCount = post.body?.trim().split(/\s+/).length ?? 0;
	const readingTime = Math.max(1, Math.round(wordCount / 200));
	return { ...post, readingTime };
});

const allTags = Array.from(new Set(posts.flatMap((p) => p.data.tags ?? []))).sort();
const totalPosts = posts.length;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 650px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 1em;
			}

			.title {
				margin-bottom: 1em;
				padding: 1em 0;
				text-align: center;
				line-height: 1;
			}
			.title h1 {
				margin: 0 0 0.5em 0;
			}

			/* Filter pills */
			.filter-bar {
				margin-bottom: 0.75em;
				display: flex;
				flex-direction: column;
				gap: 0.6em;
			}
			.filter-label {
				font-size: 0.8em;
				font-weight: 700;
				letter-spacing: 0.08em;
				text-transform: uppercase;
				color: rgb(var(--gray));
			}
			.pill-group {
				display: flex;
				flex-wrap: wrap;
				gap: 0.4em;
			}
			.pill {
				padding: 0.3em 0.85em;
				border-radius: 999px;
				border: 1.5px solid rgba(255, 255, 255, 0.12);
				background: transparent;
				color: rgb(var(--gray-dark));
				font-size: 0.82em;
				font-weight: 500;
				cursor: pointer;
				transition: all 0.15s ease;
				font-family: inherit;
				line-height: 1.5;
			}
			.pill:hover {
				border-color: var(--accent);
				color: var(--accent);
			}
			.pill.active {
				background: var(--accent);
				border-color: var(--accent);
				color: #fff;
			}

			.post-count {
				font-size: 0.82em;
				color: rgb(var(--gray));
				margin: 0 0 1.25em 0;
			}

			.empty-state {
				display: none;
				text-align: center;
				padding: 3em 1em;
				color: rgb(var(--gray));
				font-size: 0.95em;
			}

			ul {
				list-style-type: none;
				padding: 0;
				margin: 0;
				display: flex;
				flex-direction: column;
				gap: 0;
			}
			li {
				padding: 1em 0.75em;
				border-radius: 8px;
				border-left: 3px solid transparent;
				transition: background 0.2s ease, border-color 0.2s ease;
			}
			li:hover {
				background: rgba(129, 140, 248, 0.04);
				border-left-color: var(--accent);
			}
			li * {
				text-decoration: none;
				transition: 0.2s ease;
			}
			li a {
				display: block;
				margin-bottom: 0.4em;
			}
			.post-title {
				margin: 0 0 0.2em 0;
				color: rgb(var(--black));
				line-height: 1.3;
				font-size: 1rem;
			}
			.post-meta {
				display: flex;
				align-items: center;
				gap: 0.5em;
				flex-wrap: wrap;
				font-size: 0.85em;
				color: rgb(var(--gray));
				margin: 0;
			}
			.meta-sep {
				opacity: 0.4;
			}
			li:hover .post-title,
			li:hover .post-meta {
				color: rgb(var(--accent));
			}
			.post-tags {
				display: flex;
				flex-wrap: wrap;
				gap: 0.3em;
				margin-top: 0.5em;
			}
			.post-tag {
				display: inline-block;
				padding: 0.15em 0.55em;
				border: 1px solid rgba(255, 255, 255, 0.1);
				border-radius: 4px;
				font-size: 0.75em;
				color: rgb(var(--gray));
				background: transparent;
			}
			hr {
				border: none;
				border-top: 1px solid rgba(255, 255, 255, 0.06);
				margin: 0;
			}

			html[data-theme="light"] .pill {
				border-color: rgba(0, 0, 0, 0.12);
			}
			html[data-theme="light"] .post-tag {
				border-color: rgba(0, 0, 0, 0.1);
			}
			html[data-theme="light"] hr {
				border-top-color: rgba(0, 0, 0, 0.07);
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="title">
				<h1>Blog</h1>
			</div>
			<section>
				{allTags.length > 0 && (
					<div class="filter-bar">
						<span class="filter-label">Filter by tag</span>
						<div class="pill-group" id="tag-pills">
							<button class="pill active" data-value="">All</button>
							{allTags.map((tag) => (
								<button class="pill" data-value={tag}>{tag}</button>
							))}
						</div>
					</div>
				)}

				<p class="post-count">
					Showing <span id="visible-count">{totalPosts}</span> of {totalPosts} posts
				</p>

				<p class="empty-state" id="empty-state">No posts match this tag.</p>

				<ul id="post-list">
					{postsWithMeta.map((post) => (
						<li class="scroll-reveal post-item" data-tags={(post.data.tags ?? []).join(',')}>
							<a href={`/blog/${post.id}/`}>
								<h4 class="post-title">{post.data.title}</h4>
								<p class="post-meta">
									<FormattedDate date={post.data.pubDate} />
									<span class="meta-sep">·</span>
									<span>{post.readingTime} min read</span>
								</p>
							</a>
							{(post.data.tags ?? []).length > 0 && (
								<div class="post-tags">
									{(post.data.tags ?? []).map((tag) => (
										<span class="post-tag">{tag}</span>
									))}
								</div>
							)}
							<hr />
						</li>
					))}
				</ul>
			</section>
		</main>
		<div class="sticky-container" transition:persist="sticky-sidebar">
			<SocialMediaLine />
			<EmailLine email={EMAIL} />
		</div>
		<Footer />
		<script>
			let filterController: AbortController | null = null;

			function initBlogFilter() {
				if (filterController) filterController.abort();
				filterController = new AbortController();
				const { signal } = filterController;

				const pills = document.querySelectorAll<HTMLButtonElement>("#tag-pills .pill");
				const items = document.querySelectorAll<HTMLElement>(".post-item");
				const countEl = document.getElementById("visible-count");
				const emptyEl = document.getElementById("empty-state");

				if (!pills.length) return;

				pills.forEach((pill) => {
					pill.addEventListener("click", () => {
						pills.forEach((p) => p.classList.remove("active"));
						pill.classList.add("active");
						const filter = pill.dataset.value ?? "";

						let visible = 0;
						items.forEach((item) => {
							const tags = item.dataset.tags?.split(",").filter(Boolean) ?? [];
							const show = !filter || tags.includes(filter);
							item.style.display = show ? "" : "none";
							if (show) visible++;
						});

						if (countEl) countEl.textContent = String(visible);
						if (emptyEl) emptyEl.style.display = visible === 0 ? "block" : "none";
					}, { signal });
				});
			}

			initBlogFilter();
			document.addEventListener('astro:page-load', initBlogFilter);
		</script>
	</body>
</html>
