---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import SocialMediaLine from '../components/SocialMediaLine.astro';
import EmailLine from '../components/EmailLine.astro';
import { SITE_TITLE, SITE_DESCRIPTION, EMAIL } from '../consts';
import "../styles/about.css";
import Footer from '../components/Footer.astro';

const stack = [
	'Python', 'Java', 'TypeScript', 'REST APIs', 'Azure',
	'Kubernetes', 'Docker', 'CI/CD', 'SQL', 'Playwright',
	'Distributed Systems', 'IoT', 'AI',
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section id="about_section">
				<h5 class="delay_order1" id="greeting-h5"><span class="wave-emoji">👋🏼</span><span id="typewriter-target"> Hi, I'm <b>Lucas Da Cruz</b>.</span></h5>

				<p class="delay_order2">
					I'm a Software Engineer with 4+ years of experience in backend development, API design,
					distributed systems, and DevOps. I'm drawn to building things that are scalable and reliable,
					and I'm always exploring what's next in AI, cloud, and robotics.
				</p>

				<p class="delay_order3">
					At <a class="underline" href="https://www.ecolab.com/" target="_blank">Ecolab</a> I work as an
					AI Engineer, and have previously worked across distributed IoT systems and developer tooling.
					On the side, I freelance with startups on interesting problems, most recently at
					<a class="underline" href="https://www.torchlight.care/" target="_blank">Torchlight</a>.
				</p>

				<p class="delay_order4">
					Outside of work I spend my time <a href="/library">reading</a>, cooking, blogging,
					and being a dad to three kids alongside my wife.
					Take a look at my <a href="/projects">projects</a> if you want to see what I've been building.
				</p>

				<div class="marquee-container delay_order5" aria-label="Tech stack">
					<div class="marquee-track">
						{[...stack, ...stack].map((tech, i) => (
							<span class="stack-tag" aria-hidden={i >= stack.length ? "true" : undefined}>{tech}</span>
						))}
					</div>
				</div>
			</section>
		</main>

		<div class="sticky-container" transition:persist="sticky-sidebar">
			<SocialMediaLine />
			<EmailLine email={EMAIL} />
		</div>
		<Footer />
		<script>
			function initTypewriter() {
				const target = document.getElementById('typewriter-target');
				if (!target) return;

				if (document.documentElement.classList.contains('header-animated')) {
					if (!target.innerHTML.trim()) {
						target.innerHTML = " Hi, I'm <b>Lucas Da Cruz</b>.";
					}
					return;
				}

				const h5 = target.closest('h5') as HTMLElement | null;
				if (h5) { h5.style.opacity = '1'; h5.style.animation = 'none'; }

				target.innerHTML = '';
				const cursor = document.createElement('span');
				cursor.className = 'tw-cursor';
				target.appendChild(cursor);

				const parts = [
					{ text: " Hi, I'm ", bold: false },
					{ text: 'Lucas Da Cruz', bold: true },
					{ text: '.', bold: false },
				];

				let pi = 0, ci = 0;

				function tick() {
					if (pi >= parts.length) {
						setTimeout(() => cursor.remove(), 600);
						return;
					}
					const part = parts[pi];

					if (ci === 0 && part.bold) {
						target!.insertBefore(document.createElement('b'), cursor);
					}

					const char = part.text[ci];
					if (part.bold) {
						const boldEl = cursor.previousElementSibling as HTMLElement | null;
						if (boldEl?.tagName === 'B') boldEl.textContent += char;
					} else {
						const prev = cursor.previousSibling;
						if (prev?.nodeType === Node.TEXT_NODE) {
							prev.textContent! += char;
						} else {
							target!.insertBefore(document.createTextNode(char), cursor);
						}
					}

					ci++;
					if (ci >= part.text.length) { pi++; ci = 0; }
					setTimeout(tick, 55);
				}

				setTimeout(tick, 600);
			}

			document.addEventListener('astro:page-load', initTypewriter);
		</script>
	</body>
</html>
